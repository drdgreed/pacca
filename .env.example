# PACCA Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=pacca
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# API KEYS
# =============================================================================
# Anthropic Claude API (required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinecone Vector Database (optional - uses ChromaDB locally if not set)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=pacca-guidelines

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://pacca:pacca_dev_password@localhost:5432/pacca

# For local development with SQLite (simpler setup)
# DATABASE_URL=sqlite+aiosqlite:///./pacca.db

# =============================================================================
# REDIS (Caching & Rate Limiting)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SECURITY
# =============================================================================
# Secret key for JWT tokens and session encryption
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
# Default LLM model for agents
DEFAULT_MODEL=claude-sonnet-4-20250514

# Confidence thresholds for autonomous decisions
AUTO_APPROVE_CONFIDENCE_THRESHOLD=0.85
ESCALATION_CONFIDENCE_THRESHOLD=0.75

# Maximum tokens for agent responses
MAX_TOKENS=4096

# Agent timeout in seconds
AGENT_TIMEOUT=60

# =============================================================================
# CLINICAL SETTINGS
# =============================================================================
# Complexity score threshold for automatic routing
COMPLEXITY_AUTO_APPROVE_MAX=2
COMPLEXITY_SPECIALIST_REVIEW_MIN=4

# High-cost authorization threshold (requires medical director review)
HIGH_COST_THRESHOLD=100000

# =============================================================================
# OBSERVABILITY
# =============================================================================
# Enable detailed agent tracing
ENABLE_TRACING=true

# Metrics endpoint
METRICS_ENABLED=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# Requests per minute per client
RATE_LIMIT_RPM=60

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable autonomous approvals (false = all decisions require human review)
ENABLE_AUTONOMOUS_DECISIONS=true

# Enable RAG-based guideline retrieval
ENABLE_RAG=true

# Enable mock EHR data for demo mode
DEMO_MODE=true
