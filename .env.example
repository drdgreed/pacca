# PACCA Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=pacca
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# API KEYS
# =============================================================================
# Anthropic Claude API (required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinecone Vector Database (optional - uses ChromaDB locally if not set)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=pacca-guidelines

# =============================================================================
# DATABASE
# =============================================================================
# Production: PostgreSQL 16 (full feature set — JSONB queries, connection pooling,
# row-level locking, replication). Used by default when running docker-compose.
#
# The entire data layer uses SQLAlchemy 2.0 ORM with the Repository pattern.
# Switching between databases is a single line change here — no code changes required.
# db/models.py uses PostgreSQL-native JSONB columns for audit log details and
# decision rationale, enabling indexed queries inside JSON fields.
#
# Development: SQLite (zero configuration, same ORM layer, same repository calls)
# JSONB columns fall back to TEXT in SQLite — queries still work, just without
# JSON-path indexing. Suitable for local development and unit tests.

# Uncomment the line that matches your environment:
DATABASE_URL=postgresql+asyncpg://pacca:pacca_dev_password@localhost:5432/pacca
# DATABASE_URL=sqlite+aiosqlite:///./pacca.db

# =============================================================================
# REDIS (Caching & Rate Limiting)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SECURITY
# =============================================================================
# Secret key for JWT token signing and session encryption.
# CRITICAL: Generate a unique random value for every deployment.
# Never commit a real value here. Never reuse across environments.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#
# The application will REFUSE TO START if SECRET_KEY is missing or < 32 chars.
# This is intentional fail-fast behavior to prevent insecure deployments.
SECRET_KEY=REPLACE-THIS-generate-with-python-secrets-module-min-32-chars

# JWT token lifetime in minutes.
# Default: 30 minutes (appropriate for PHI access — short window limits
# exposure if a token is intercepted).
# Minimum recommended: 15 minutes. Maximum for HIPAA-adjacent systems: 60 minutes.
TOKEN_EXPIRE_MINUTES=30

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
# Default LLM model for agents
DEFAULT_MODEL=claude-sonnet-4-20250514

# Confidence thresholds for autonomous decisions
AUTO_APPROVE_CONFIDENCE_THRESHOLD=0.95
ESCALATION_CONFIDENCE_THRESHOLD=0.90

# Maximum tokens for agent responses
MAX_TOKENS=4096

# Agent timeout in seconds
AGENT_TIMEOUT=60

# =============================================================================
# CLINICAL SETTINGS
# =============================================================================
# Complexity score threshold for automatic routing
COMPLEXITY_AUTO_APPROVE_MAX=2
COMPLEXITY_SPECIALIST_REVIEW_MIN=4

# High-cost authorization threshold (requires medical director review)
HIGH_COST_THRESHOLD=100000

# =============================================================================
# OBSERVABILITY
# =============================================================================
# OpenTelemetry configuration
# When OTEL_ENDPOINT is set, spans are exported to that collector.
# Compatible with Langfuse, Jaeger, Grafana Tempo, and any OTel-compatible backend.
# When unset, spans are printed to the console (development default).
#
# To connect Langfuse:
#   OTEL_ENDPOINT=https://cloud.langfuse.com
#
# To run Jaeger locally for development:
#   docker run -p 16686:16686 -p 4318:4318 jaegertracing/all-in-one
#   OTEL_ENDPOINT=http://localhost:4318
#   View traces at: http://localhost:16686
OTEL_ENABLED=true
OTEL_SERVICE_NAME=pacca
# OTEL_ENDPOINT=http://localhost:4318

# LLM retry configuration (tenacity exponential backoff)
# 3 attempts with 1-30 second exponential backoff between retries.
# Only retries transient errors: 429 rate limit, 5xx server errors, connection errors.
# Non-retriable errors (400, 401) fail immediately.
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_WAIT_MIN_SECONDS=1.0
LLM_RETRY_WAIT_MAX_SECONDS=30.0

# Enable detailed agent tracing (audit trail)
ENABLE_TRACING=true

# Metrics endpoint
METRICS_ENABLED=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# Requests per minute per client
RATE_LIMIT_RPM=60

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable autonomous approvals (false = all decisions require human review)
ENABLE_AUTONOMOUS_DECISIONS=true

# Enable RAG-based guideline retrieval
ENABLE_RAG=true

# Enable mock EHR data for demo mode
DEMO_MODE=true
