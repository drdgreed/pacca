# Frontend dev-server configuration. Copy to .env.local to override locally
# (.env.local is gitignored). All values here are optional — the defaults in
# vite.config.ts apply when unset.

# Backend target for the Vite dev proxy (/api and /health are forwarded here).
# Defaults to http://localhost:8000. Set this when the backend runs on a
# different port, e.g. to avoid a collision with another local service:
# VITE_BACKEND_URL=http://localhost:8001
